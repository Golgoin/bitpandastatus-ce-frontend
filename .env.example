# ==============================================================================
# API ENDPOINTS
# ==============================================================================

# The base URL for the Bitpanda Status Community API.
# Defaults to https://bitpandastatus.info if not set.
STATUS_API_BASE_URL=https://bitpandastatus.info

# The Bitpanda endpoint for checking if an asset is "new".
# Defaults to https://api.bitpanda.com/v1/prices/assets/new
BITPANDA_NEW_ASSETS_URL=https://api.bitpanda.com/v1/prices/assets/new

# Optional: Override specific API endpoints if your backend structure differs.
# STATUS_API_SETTINGS_URL=https://bitpandastatus.info/api/settings
# STATUS_API_UPDATES_URL=https://bitpandastatus.info/api/updates

# ==============================================================================
# ANALYTICS (Optional)
# ==============================================================================

# Enable/Disable Plausible analytics tracking.
NEXT_PUBLIC_PLAUSIBLE_ENABLED=false

# Your Plausible domain (e.g., yoursite.com).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com

# The URL of the Plausible script. Defaults to https://plausible.io/js/script.js
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# ==============================================================================
# UI TOGGLES & DONATIONS (Optional)
# ==============================================================================

# Enable/Disable the "Buy Me a Coffee" floating popup.
NEXT_PUBLIC_COFFEE_ENABLED=false

# The URL for your external donation page (e.g., Buy Me a Coffee, Ko-fi).
NEXT_PUBLIC_COFFEE_URL=https://coff.ee/your-handle

# Your EVM-compatible crypto address for donations.
NEXT_PUBLIC_CRYPTO_ADDRESS=your-crypto-address

# ==============================================================================
# BRANDING & SEO
# ==============================================================================

# The public URL of your deployment (used for canonical links and metadata).
NEXT_PUBLIC_BASE_URL=https://your-site.com

# The name of your site (used in page titles and social sharing).
NEXT_PUBLIC_SITE_NAME=Bitpanda Status - Community Edition

# Your social media profile link (X/Twitter).
NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/your-handle

# Your social media handle (e.g., @YourHandle).
NEXT_PUBLIC_SOCIAL_X_HANDLE=@your-handle
